ink": "linked", "meta": {"parent": "cluster:intrinsic", "scale": "atom", "atom_kind": "intrinsic"}}, {"id": "powerlaw", "kind": "intrinsic", "label": "Power-law scaling and log-linear exponents", "group": "intrinsic", "status": null, "weight": 0.5, "source": "model", "link": "linked", "meta": {"parent": "cluster:intrinsic", "scale": "atom", "atom_kind": "intrinsic"}}, {"id": "R1", "kind": "result", "label": "The adaptive loop is one object, and collapses to one return map", "group": "result", "status": null, "weight": 0.5, "source": "goal", "link": "linked", "meta": {"summary": "The four-leg adaptive loop is a single mathematical object; under scale separation and coarse measurement it reduces to one scalar return map. (ledger R1)", "scale": "result", "order": 3, "title": "Substrate: Adaptive Normal Form (the ANF graph, grown bottom-up)"}}, {"id": "eq_returnmap", "kind": "equation", "label": "e_{k+1} = (r - K_N)\\,e_k - \\alpha\\,c_N\\,e_k^{3} + \\cdots", "group": "equation", "status": null, "weight": 0.5, "source": "R1", "link": "linked", "meta": {"parent": "R1", "scale": "atom", "atom_kind": "equation"}}, {"id": "eq_gain", "kind": "equation", "label": "K_N = \\alpha\\,\\chi_N\\,g", "group": "equation", "status": null, "weight": 0.5, "source": "R1", "link": "linked", "meta": {"parent": "R1", "scale": "atom", "atom_kind": "equation"}}, {"id": "fig_1", "kind": "figure", "label": "the adaptive loop: object panels, verb arcs, colour-coded governing equations", "group": "figure", "status": null, "weight": 0.5, "source": "R1", "link": "linked", "meta": {"parent": "R1", "scale": "atom", "atom_kind": "figure"}}, {"id": "R2", "kind": "result", "label": "The susceptibility-exponent law and its RG shadow", "group": "result", "status": null, "weight": 0.5, "source": "goal", "link": "linked", "meta": {"summary": "The order-parameter susceptibility obeys a power law whose exponent is the log of the decimation eigenvalue; the dynamical transition is the shadow of the RG fixed point, and (Gamma, psi) classify universality. (ledger R2)", "scale": "result", "order": 4, "title": "Substrate: Adaptive Normal Form (the ANF graph, grown bottom-up)"}}, {"id": "eq_chi", "kind": "equation", "label": "\\chi_N \\sim A\\,N^{\\psi},\\quad \\psi = \\log_n \\lambda_0", "group": "equation", "status": null, "weight": 0.5, "source": "R2", "link": "linked", "meta": {"parent": "R2", "scale": "atom", "atom_kind": "equation"}}, {"id": "fig_2a", "kind": "figure", "label": "susceptibility power law, psi=1/2 slope triangle, O(1/N) inset", "group": "figure", "status": null, "weight": 0.5, "source": "R2", "link": "linked", "meta": {"parent": "R2", "scale": "atom", "atom_kind": "figure"}}, {"id": "R3", "kind": "result", "label": "psi is a complete classifier; instability is a flip bifurcation", "group": "result", "status": null, "weight": 0.5, "source": "goal", "link": "linked", "meta": {"summary": "psi sorts every system into three classes with three fates; loss of stability is a flip bifurcation at a finite critical size N_c. (ledger R3)", "scale": "result", "order": 5, "title": "Substrate: Adaptive Normal Form (the ANF graph, grown bottom-up)"}}, {"id": "eq_Nc", "kind": "equation", "label": "N_c \\sim \\left(\\dfrac{K_c}{\\alpha\\,g\\,A}\\right)^{1/\\psi}", "group": "equation", "status": null, "weight": 0.5, "source": "R3", "link": "linked", "meta": {"parent": "R3", "scale": "atom", "atom_kind": "equation"}}, {"id": "fig_2b", "kind": "figure", "label": "the psi-trichotomy schematic", "group": "figure", "status": null, "weight": 0.5, "source": "R3", "link": "linked", "meta": {"parent": "R3", "scale": "atom", "atom_kind": "figure"}}, {"id": "fig_2c", "kind": "figure", "label": "the flip fork, sqrt(N-Nc) two-cycle", "group": "figure", "status": null, "weight": 0.5, "source": "R3", "link": "linked", "meta": {"parent": "R3", "scale": "atom", "atom_kind": "figure"}}, {"id": "R4", "kind": "result", "label": "Hierarchy is renormalisation time; minimum depth is logarithmic", 